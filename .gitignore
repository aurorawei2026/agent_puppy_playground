# Secrets — never commit
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
*.egg-info/

# Simulation output: ignore one-off timestamped runs (they can be large),
# but keep latest.json + sample-*.json so the deployed viewer has
# demo runs to load.
playground/runs/*.json
!playground/runs/.gitkeep
!playground/runs/latest.json
!playground/runs/sample-*.json

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
