# Secrets — never commit
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
*.egg-info/

# Simulation output: ignore timestamped runs (they can be large),
# but keep latest.json so the deployed viewer has a demo run to load.
playground/runs/*.json
!playground/runs/.gitkeep
!playground/runs/latest.json

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
